# Plaid API credentials (get from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox

# QuickBooks Online API (get from https://developer.intuit.com)
QUICKBOOKS_CLIENT_ID=your_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_secret_here
QUICKBOOKS_ENV=sandbox
QUICKBOOKS_REDIRECT_URI=https://your-domain.vercel.app/api/quickbooks/callback

# Vercel KV (auto-populated when you connect a KV store in Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Trigger redeploy
